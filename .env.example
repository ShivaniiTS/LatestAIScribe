# ─────────────────────────────────────────────────
# AI Scribe Pro — Environment Configuration
# Copy to .env and fill in values for your deployment
# ─────────────────────────────────────────────────

# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aiscribe:changeme@localhost:5432/aiscribe

# ── HuggingFace (for pyannote diarization) ────────
HF_TOKEN=

# ── Ollama ────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/v1

# ── MT SFTP ───────────────────────────────────────
MT_SFTP_HOST=
MT_SFTP_PORT=22
MT_SFTP_USER=
MT_SFTP_PASSWORD=
MT_SFTP_BASE_PATH=/AI-Scribe
MT_SFTP_MASTER_UPLOAD=/AI-Scribe/Master_Upload_Folder

# ── MT Email Reports ─────────────────────────────
MT_SMTP_HOST=
MT_SMTP_PORT=587
MT_SMTP_USER=
MT_SMTP_PASSWORD=
MT_REPORT_RECIPIENTS=

# ── Storage ───────────────────────────────────────
STORAGE_TYPE=local
AUDIO_STORAGE_PATH=data/audio

# ── Server ────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:9001,http://localhost:9002

# ── Security ──────────────────────────────────────
SECRET_KEY=ahau283baks930-iwebe730-awc8392
